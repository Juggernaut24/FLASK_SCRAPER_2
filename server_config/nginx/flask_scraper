server {
    listen 80;
    # Erstat 'localhost' med din server-IP, hvis du kender den, ellers lad den stå
    server_name 192.168.0.184;

    location / {
        include proxy_params;
        proxy_pass http://127.0.0.1:8000;
        
        # Vi øger også timeout her, så Nginx ikke giver op før din scraper er færdig
        proxy_read_timeout 300s;
        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
    }
}
